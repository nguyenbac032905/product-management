extends ../../layouts/default.pug
include ../../mixins/moment.pug

block main
    h1.mb-4 Danh sách mã giảm giá
    .card.mb-3
        .card-header Danh sách
        .card-body
            .row 
                .col-8
                .col-4 
                    a(href=`${prefixAdmin}/coupon/create` class="btn btn-outline-success") + Thêm mới
            table(class="table table-hover table-sm")
                thead
                    tr
                        th STT
                        th Mã
                        th Loại giảm giá
                        th Giá trị giảm
                        th Trạng thái
                        th Ngày bắt đầu 
                        th Ngày hết hạn
                        th Hành động
                tbody
                    each item, index in records
                        tr
                            td #{index + 1}
                            td #{item.code}
                            td #{item.discountType}
                            td #{item.discountType=="percent" ? `${item.discountValue} %` : `${item.discountValue.toLocaleString()} đ`}
                            td
                                if item.status === "active"
                                    a(
                                        href="javascript:;"
                                        class="badge badge-success"
                                        data-status="active"
                                    ) Hoạt động
                                else
                                    a(
                                        href="javascript:;"
                                        class="badge badge-danger"
                                        data-status="inactive"
                                    ) Dừng hoạt động
                            td 
                                +formatDateTime(item.startDate)
                            td 
                                +formatDateTime(item.endDate)
                            td
                                a(
                                    class="btn btn-secondary btn-sm"
                                    href=`${prefixAdmin}/coupon/detail/${item.id}`
                                ) Chi tiết
                                a(
                                    class="btn btn-warning btn-sm ml-1"
                                    href=`${prefixAdmin}/coupon/edit/${item.id}`
                                ) Sửa
                                button(
                                    class="btn btn-danger btn-sm ml-1"
                                    type="button"
                                ) Xóa
                                    